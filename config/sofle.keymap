#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/outputs.h>

// Encoders
&sensors { triggers-per-rotation = <30>; };
&left_encoder { steps = <60>; };
&right_encoder { steps = <60>; };

#define BASE     0
#define ALT_LAYER 1
#define SYMBOLS  2
#define NAV      3
#define SYSTEM   4

/ {
    // Activate SYSTEM layer by holding Raise (Symbols) and Lower (Nav) together
    conditional_layers {
        compatible = "zmk,conditional-layers";
        system_layer {
            if-layers = <SYMBOLS NAV>;
            then-layer = <SYSTEM>;
        };
    };

    // Phase 1 combos: the four sticky-modifier combos + Command Palette.
    // Raise x2/x3 and Lower x2/x3 (sticky-layer / lock-layer via tap-dance)
    // are deferred to Phase 2 as agreed.
    combos {
        compatible = "zmk,combos";
        sticky_ctrl {
            bindings = <&sk LCTRL>;
            key-positions = <52 57>;
        };
        sticky_alt {
            bindings = <&sk LALT>;
            key-positions = <51 58>;
        };
        sticky_gui {
            bindings = <&sk LGUI>;
            key-positions = <50 59>;
        };
        sticky_shift {
            bindings = <&sk LSHFT>;
            key-positions = <36 49>;
        };
        cmd_palette {
            bindings = <&kp LG(LA(SPACE))>;
            key-positions = <54 55>;
        };
    };

    behaviors {
        caps: caps {
            compatible = "zmk,behavior-caps-word";
            label = "CAPS";
            #binding-cells = <0>;
            continue-list = <POUND MINUS BACKSPACE UNDERSCORE>;
        };
        // Mouse scroll on encoder rotation (Base-left, System-right)
        scroll: scroll {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
        };
        // Explicitly unbound encoder rotation (System-left)
        rot_none: rot_none {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&none>, <&none>;
        };
    };

    macros {
        // ZMK has no native "00" keypad keycode (only KP_N0-KP_N9), so this
        // taps 0 twice instead.
        zero_zero: zero_zero {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap &kp N0 &kp N0>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "QWERTY";
            // QWERTY default (William's arm/typing-speed accommodation while
            // learning Colemak-DH — see project notes). QWCM key (System
            // layer) toggles the Colemak-DH overlay on/off for practice.
            // Positions 42/43 (mid bottom-row) are the encoder push-buttons:
            // left=Middle-click, right=Return.
            // ---------------------------------------------------------------------------------------------
            // |   Esc  |  1  |  2  |  3  |  4  |  5  |                | 6  |  7  |  8  |  9  |  0  |   -   |
            // |  Tab   |  Q  |  W  |  E  |  R  |  T  |                | Y  |  U  |  I  |  O  |  P  | BkSp  |
            // |  BkSp  |  A  |  S  |  D  |  F  |  G  |                | H  |  J  |  K  |  L  |  ;  |   '   |
            // | Shift  |  Z  |  X  |  C  |  V  |  B  | [MidClk]|[Ret] | N  |  M  |  ,  |  .  |  /  | Shift |
            //                | GUI | Alt | Ctrl| Raise| Space |  | Return | Lower| Ctrl | Alt | GUI |
            bindings = <
&kp ESC         &kp N1  &kp N2  &kp N3  &kp N4  &kp N5                                       &kp N6  &kp N7    &kp N8    &kp N9   &kp N0    &kp MINUS
&kp TAB         &kp Q   &kp W   &kp E   &kp R   &kp T                                        &kp Y   &kp U     &kp I     &kp O    &kp P     &kp BSPC
&kp BSPC        &kp A   &kp S   &kp D   &kp F   &kp G                                        &kp H   &kp J     &kp K     &kp L    &kp SEMI  &kp SQT
&kp LSHFT       &kp Z   &kp X   &kp C   &kp V   &kp B   &mkp MCLK        &kp RETURN          &kp N   &kp M     &kp COMMA &kp DOT  &kp FSLH  &kp RSHFT
                        &kp LGUI &kp LALT &kp LCTRL &mo SYMBOLS &kp SPACE  &kp RETURN &mo NAV  &kp RCTRL &kp LALT &kp RGUI
            >;
            sensor-bindings = <&scroll &inc_dec_kp RIGHT LEFT>;
        };

        colemak_layer {
            display-name = "Colemak-DH";
            // Thin overlay — transparent everywhere except the 26 letters.
            // Toggled on/off by the QWCM key on the System layer (&tog ALT_LAYER).
            // QWERTY (default_layer) is now the default; this overlay is reached
            // via the QWCM toggle key when Colemak-DH practice is wanted.
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                                &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp Q   &kp W   &kp F   &kp P   &kp B                                 &kp J   &kp L   &kp U   &kp Y   &kp SEMI &trans
&trans  &kp A   &kp R   &kp S   &kp T   &kp G                                 &kp M   &kp N   &kp E   &kp I   &kp O   &trans
&trans  &kp Z   &kp X   &kp C   &kp D   &kp V   &trans          &trans        &kp K   &kp H   &kp COMMA &kp DOT &kp FSLH &trans
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            // No sensor-bindings — rotation falls through to Base.
        };

        symbols_layer {
            display-name = "Symbols";
            // Reached by holding Raise (left thumb). Numpad aligned under the
            // number row. Encoder press: left=Mute, right=Ctrl+0 (reset zoom).
            bindings = <
&trans  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5                                     &trans  &kp N7  &kp N8  &kp N9    &kp FSLH  &kp MINUS
&trans  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10                                    &trans  &kp N4  &kp N5  &kp N6    &kp ASTRK &kp DEL
&kp DEL &kp F11 &kp F12 &kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp TILDE       &trans  &kp N1  &kp N2  &kp N3    &kp PLUS  &kp RETURN
&trans  &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT_BRACE &kp RIGHT_BRACE &kp GRAVE &kp C_MUTE  &kp LC(N0)   &trans  &kp N0  &zero_zero &kp DOT &kp EQUAL &kp RETURN
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp LC(EQUAL) LC(MINUS)>;
        };

        nav_layer {
            display-name = "Navigation";
            // Reached by holding Lower (right thumb).
            // Encoder press: left=Home, right=End.
            // Ctrl+Backspace/Ctrl+Delete on right encoder Ctrl-row (see V8 spec)
            // is a modifier-conditional behavior — deferred to Phase 2 along
            // with the rest of the modifier-aware encoder logic; default
            // (unmodified) rotation only for now.
            bindings = <
&trans  &kp INS      &kp PSCRN   &trans      &trans      &trans                                    &trans   &trans   &trans   &trans    &trans  &trans
&trans  &kp LALT     &kp LCTRL   &kp LSHFT   &caps        &kp CLCK                                 &kp PG_UP &kp HOME &kp UP   &kp END   &trans  &kp DEL
&kp DEL &kp K_UNDO    &kp K_CUT   &kp K_COPY  &kp K_PASTE &trans                                    &kp PG_DN &kp LEFT &kp DOWN &kp RIGHT &trans  &trans
&trans  &trans        &trans      &trans      &trans      &trans   &kp HOME        &kp END          &kp K_APP &trans  &trans   &trans    &trans  &trans
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&inc_dec_kp LC(DOWN) LC(UP) &inc_dec_kp LC(RIGHT) LC(LEFT)>;
        };

        system_layer {
            display-name = "System";
            // Reached by holding Raise+Lower together (conditional layer above).
            // QWCM toggle key lives here (row4, col1) — toggles the
            // Colemak-DH overlay layer on/off.
            bindings = <
&bt BT_CLR_ALL  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4                          &none       &none      &none          &none        &none        &out OUT_TOG
&ext_power EP_TOG &none       &none         &none         &none         &studio_unlock                       &msc SCRL_UP &none      &mmv MOVE_UP   &none        &none        &none
&none           &none         &none         &none         &none         &trans                                &msc SCRL_DOWN &mmv MOVE_LEFT &mmv MOVE_DOWN &mmv MOVE_RIGHT &none    &none
&none           &tog ALT_LAYER   &none         &none         &none         &none    &none          &none          &none      &mkp LCLK  &mkp MCLK      &mkp RCLK    &none        &none
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&rot_none &scroll>;
        };
    };
};
