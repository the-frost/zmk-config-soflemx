#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/outputs.h>

// Encoders
&sensors { triggers-per-rotation = <20>; };
&left_encoder { steps = <80>; };
&right_encoder { steps = <80>; };
// V15: was triggers-per-rotation=30 / steps=60 (ratio 2 counts/trigger),
// which fired two logical triggers per physical detent on this hardware.
// 20/80 (ratio 4 counts/trigger) matches standard 20-detent EC11 encoders.
// First-guess fix, not yet hardware-verified — may need further tuning.

#define BASE     0
#define ALT_LAYER 1
#define SYMBOLS  2
#define NAV      3
#define SYSTEM   4

/ {
    // Activate SYSTEM layer by holding Raise (Symbols) and Lower (Nav) together
    conditional_layers {
        compatible = "zmk,conditional-layers";
        system_layer {
            if-layers = <SYMBOLS NAV>;
            then-layer = <SYSTEM>;
        };
    };

    // Sticky-modifier combos and Raise/Lower tap-dance (sticky/lock layers)
    // were removed by request — accidental repeated presses risked locking
    // a layer/modifier on unintentionally. Command Palette combo kept.
    behaviors {
        caps: caps {
            compatible = "zmk,behavior-caps-word";
            label = "CAPS";
            #binding-cells = <0>;
            continue-list = <POUND MINUS BACKSPACE UNDERSCORE>;
        };
        // Explicitly unbound encoder rotation (System layer, both encoders —
        // holding both Raise+Lower to reach this layer while also spinning
        // an encoder isn't practical, so left deliberately inert)
        rot_none: rot_none {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&none>, <&none>;
        };

        // ---------------------------------------------------------------
        // PHASE 2: Home-row mods — bilateral (cross-hand) positional hold-tap.
        // One behavior per hand; mod + tap keycode supplied per key position
        // below, so the same hml/hmr definitions serve both Base (QWERTY)
        // and the Colemak-DH overlay (only the tap letter differs per layer).
        // hold-trigger-key-positions restricts a "hold" to only register when
        // confirmed by a key press on the OPPOSITE hand (reduces accidental
        // mod-firing during normal same-hand typing rolls).
        // ---------------------------------------------------------------
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            label = "HRM_LEFT";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <120>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 43 44 45 46 47 48 49 55 56 57 58 59>;
            hold-trigger-on-release;
        };
        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            label = "HRM_RIGHT";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <120>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29 36 37 38 39 40 41 42 50 51 52 53 54>;
            hold-trigger-on-release;
        };

        // ---------------------------------------------------------------
        // PHASE 2/2.1: Modifier-conditional encoders (nested mod-morph,
        // priority Ctrl > Alt > Shift > default). Only built where the
        // "held" variant is a genuinely different action — Base-right stays
        // untouched (all its variants are free Mod+key stacking). Navigation
        // needed real branching added for ctrl_held only (V15 fix — Ctrl+
        // PageUp/PageDown and Ctrl+Delete/Backspace are NOT simple stacking,
        // they're different keys entirely; shift_held/alt_held on Nav remain
        // free).
        //
        // V15: Base-left default/shift direction reversed (CW=Down,
        // CCW=Up) per feel preference. Base-left's alt_held now sends bare
        // Tab/Shift+Tab (not Alt+Tab/Alt+Shift+Tab) so the real, already-held
        // Alt modifier stays down across repeated taps — this keeps
        // Windows' Alt-Tab switcher UI open until Alt is released, instead
        // of flashing and dismissing immediately.
        //
        // NOTE: the keymap-current YAML/SVG previously had Base-right and
        // both Navigation encoders' CW/CCW documentation swapped vs what the
        // firmware actually sends — fixed in V15 docs.
        // ---------------------------------------------------------------

        // V16: bl_cw/bl_ccw mod-morph chains removed — base-left encoder
        // rotation is now a plain inc_dec_kp (see sensor-bindings below), so
        // any physically-held modifier (Ctrl/Alt/Shift) stacks naturally
        // onto Down/Up without needing dedicated behaviors.
        // V17: bl_press/bl_press_a removed entirely — both Base encoders'
        // push-buttons (positions 7/8 in row 4) are now unbound (&none).
        // Rotation-only on both encoders; pressing them wasn't comfortable
        // enough to be worth keeping a press action.

        sl_cw_a: sl_cw_a {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_VOL_UP>, <&kp C_NEXT>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        sl_cw: sl_cw {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&sl_cw_a>, <&kp C_BRI_UP>;
            mods = <(MOD_LCTL|MOD_RCTL)>;
        };
        sl_ccw_a: sl_ccw_a {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_VOL_DN>, <&kp C_PREV>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        sl_ccw: sl_ccw {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&sl_ccw_a>, <&kp C_BRI_DN>;
            mods = <(MOD_LCTL|MOD_RCTL)>;
        };
        sl_press_a: sl_press_a {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_MUTE>, <&kp C_PP>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        sl_press: sl_press {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&sl_press_a>, <&none>;
            mods = <(MOD_LCTL|MOD_RCTL)>;
        };

        // V16: sr_cw_s/sr_ccw_s (shift-held Ctrl+Y/Ctrl+Z) and the whole
        // sr_press chain (shift/ctrl/alt press variants: PrtScn, Ctrl+S,
        // Alt+F4) were removed by request. Press now just sends Ctrl+0
        // directly in the layer bindings (no behavior needed). Rotation's
        // shift branch folded away — shift+encoder now falls through to
        // the same default as no modifier.
        sr_cw_a: sr_cw_a {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            // V20 fix: bare TAB (not LA(TAB)) so the real, already-held Alt
            // stays down across repeated taps -- keeps the Windows Alt-Tab
            // switcher open instead of flashing/dismissing each rotation.
            bindings = <&kp LC(EQUAL)>, <&kp TAB>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        sr_cw: sr_cw {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&sr_cw_a>, <&kp LC(TAB)>;
            mods = <(MOD_LCTL|MOD_RCTL)>;
        };
        sr_ccw_a: sr_ccw_a {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            // V20 fix: bare Shift+Tab (not Alt+Shift+Tab) -- see sr_cw_a note.
            bindings = <&kp LC(MINUS)>, <&kp LS(TAB)>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
        sr_ccw: sr_ccw {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&sr_ccw_a>, <&kp LC(LS(TAB))>;
            mods = <(MOD_LCTL|MOD_RCTL)>;
        };

        // Navigation ctrl-held branches (V15): default (Down/Up, Right/Left)
        // is free with real Shift/Alt held (natural stacking), but ctrl_held
        // sends genuinely different keys (PageUp/PageDown, Delete/Backspace)
        // so it needs real branching like the others above.
        // V16: nav_left_cw/ccw and nav_right_cw/ccw mod-morph chains
        // removed — both Nav encoders are now plain inc_dec_kp (PgUp/PgDn,
        // Home/End — see sensor-bindings below), so held modifiers stack
        // naturally instead of needing explicit branches.

        // Sensor-rotate wrappers: sensor-bindings takes ONE entry per
        // encoder (not per direction), and that entry must itself be a
        // #sensor-binding-cells=0 behavior with separate cw/ccw bindings
        // (same pattern as rot_none above). These wrap the mod-morph chains
        // above so they can be used in sensor-bindings.
        sym_left_rot: sym_left_rot {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&sl_cw>, <&sl_ccw>;
        };
        sym_right_rot: sym_right_rot {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&sr_cw>, <&sr_ccw>;
        };
    };

    macros {
        // ZMK has no native "00" keypad keycode (only KP_N0-KP_N9), so this
        // taps 0 twice instead.
        zero_zero: zero_zero {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap &kp N0 &kp N0>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "QWERTY";
            // QWERTY default (William's arm/typing-speed accommodation while
            // learning Colemak-DH — see project notes). QWCM key (System
            // layer) toggles the Colemak-DH overlay on/off for practice.
            // Positions 42/43 (mid bottom-row) are the encoder push-buttons.
            // PHASE 2: home-row mods on A S D F / J K L ; (CAGS order,
            // pinky->index: Ctrl, Alt, GUI, Shift). Thumb row reordered to
            // match (Ctrl outermost, GUI innermost) for consistency.
            // Encoder rotation/press now modifier-conditional (see behaviors
            // block above).
            // ---------------------------------------------------------------------------------------------
            // |   Esc  |  1  |  2  |  3  |  4  |  5  |                | 6  |  7  |  8  |  9  |  0  |   -   |
            // |  Tab   |  Q  |  W  |  E  |  R  |  T  |                | Y  |  U  |  I  |  O  |  P  | BkSp  |
            // |  BkSp  | A/Ctrl | S/Alt | D/GUI | F/Shift |  G  |      | H  | J/Shift | K/GUI | L/Alt | ;/Ctrl |   '   |
            // | Shift  |  Z  |  X  |  C  |  V  |  B  | [MidClk*]|[Ret] | N  |  M  |  ,  |  .  |  /  | Shift |
            //                | Ctrl | Alt | GUI| Raise| Space |  | Return | Lower| GUI | Alt | Ctrl |
            bindings = <
&kp ESC         &kp N1  &kp N2  &kp N3  &kp N4  &kp N5                                                                &kp N6  &kp N7    &kp N8    &kp N9   &kp N0    &kp MINUS
&kp TAB         &kp Q   &kp W   &kp E   &kp R   &kp T                                                                 &kp Y   &kp U     &kp I     &kp O    &kp P     &kp BSPC
&kp BSPC        &hml LCTRL A &hml LGUI S &hml LALT D &hml LSHFT F &kp G                                               &kp H   &hmr RSHFT J &hmr RALT K &hmr RGUI L &hmr RCTRL SEMI &kp SQT
&kp LSHFT       &kp Z   &kp X   &kp C   &kp V   &kp B   &none        &none                                   &kp N   &kp M     &kp COMMA &kp DOT  &kp FSLH  &kp RSHFT
                        &kp LCTRL &kp LGUI &kp LALT &mo SYMBOLS &kp SPACE  &kp RETURN &mo NAV  &kp RALT &kp RGUI &kp RCTRL
            >;
            sensor-bindings = <&inc_dec_kp DOWN UP &inc_dec_kp RIGHT LEFT>;
        };

        colemak_layer {
            display-name = "Colemak-DH";
            // Thin overlay — transparent everywhere except the 26 letters.
            // Toggled on/off by the QWCM key on the System layer (&tog ALT_LAYER).
            // QWERTY (default_layer) is now the default; this overlay is reached
            // via the QWCM toggle key when Colemak-DH practice is wanted.
            // PHASE 2: home-row mods duplicated here with Colemak-DH letters
            // (A/Ctrl unchanged; R/Alt, S/GUI, T/Shift; mirrored N/Shift,
            // E/GUI, I/Alt, O/Ctrl) — same physical positions/mods as Base.
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                                                          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp Q   &kp W   &kp F   &kp P   &kp B                                                            &kp J   &kp L   &kp U   &kp Y   &kp SEMI &trans
&trans  &hml LCTRL A &hml LGUI R &hml LALT S &hml LSHFT T &kp G                                           &kp M   &hmr RSHFT N &hmr RALT E &hmr RGUI I &hmr RCTRL O &trans
&trans  &kp Z   &kp X   &kp C   &kp D   &kp V   &trans          &trans                                   &kp K   &kp H   &kp COMMA &kp DOT &kp FSLH &trans
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            // No sensor-bindings — rotation falls through to Base.
        };

        symbols_layer {
            display-name = "Symbols";
            // Reached by holding Raise (left thumb). Numpad aligned under the
            // number row. PHASE 2: encoder press/rotation now modifier-
            // conditional (Ctrl=brightness/zoom-tabs, Alt=track/window-tabs,
            // Shift on right encoder=undo/redo/printscreen — see behaviors).
            bindings = <
&kp LG(SPACE)  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5                                     &tog SYMBOLS  &kp N7  &kp N8  &kp N9    &kp FSLH  &kp MINUS
&kp LA(GRAVE)  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10                                    &trans  &kp N4  &kp N5  &kp N6    &kp ASTRK &kp DEL
&kp DEL &kp F11 &kp F12 &kp TILDE &kp GRAVE &kp EQUAL       &kp BACKSLASH  &kp N1  &kp N2  &kp N3    &kp PLUS  &kp RETURN
&trans  &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT_BRACE &kp RIGHT_BRACE &kp MINUS &sl_press  &kp LC(N0)   &kp PIPE  &kp N0  &zero_zero &kp DOT &kp EQUAL &kp RETURN
                        &trans  &trans  &trans  &trans  &kp RETURN    &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&sym_left_rot &sym_right_rot>;
        };

        nav_layer {
            display-name = "Navigation";
            // Reached by holding Lower (right thumb).
            // V20: full left-hand mirror of the right-hand navigation keys,
            // using QWERTY finger positions as the guide:
            //   Row2: Q=Caps Word, W=Home, E=Up, R=End, T=Page Up
            //   Row3: A=Caps Lock, S=Left, D=Down, F=Right, G=Page Down
            //   Row4: Z=Insert, X=Print Screen, C=Pause/Break, V=Scroll Lock
            // Right hand is unchanged (Home-row 2/3, arrows/PgUp/PgDn already
            // there) -- both hands now give the same functions.
            // V15: Undo/Cut/Copy/Paste and the bare Ctrl/Alt/Shift row were
            // removed (no purpose on this layer; use home-row mods instead).
            // Encoder press: unbound on both (see V16/V17 notes). Encoder
            // rotation ctrl_held branches (PageUp/PageDown, Delete/Backspace)
            // instead of relying on natural stacking (see behaviors above).
            bindings = <
&trans  &trans       &trans      &trans      &trans      &trans                                    &tog NAV &trans   &trans   &trans    &trans  &trans
&trans  &caps        &kp HOME    &kp UP      &kp END     &kp PG_UP                                 &kp PG_UP &kp HOME &kp UP   &kp END   &trans  &kp DEL
&kp DEL &kp CLCK      &kp LEFT    &kp DOWN    &kp RIGHT   &kp PG_DN                                 &kp PG_DN &kp LEFT &kp DOWN &kp RIGHT &trans  &trans
&trans  &kp INS       &kp PSCRN   &kp PAUSE_BREAK &kp SLCK &trans   &trans        &trans          &kp K_APP &trans  &trans   &trans    &trans  &trans
                        &trans  &trans  &trans  &trans  &trans    &kp SPACE  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&inc_dec_kp PG_DN PG_UP &inc_dec_kp END HOME>;
        };

        system_layer {
            display-name = "System";
            // Reached by holding Raise+Lower together (conditional layer above).
            // QWCM toggle key lives here (row4, col1) — toggles the
            // Colemak-DH overlay layer on/off.
            bindings = <
&bt BT_CLR_ALL  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4                          &tog SYSTEM       &none      &none          &none        &none        &out OUT_TOG
&ext_power EP_TOG &none       &none         &none         &none         &studio_unlock                       &msc SCRL_UP &none      &mmv MOVE_UP   &none        &none        &none
&none           &none         &none         &none         &none         &trans                                &msc SCRL_DOWN &mmv MOVE_LEFT &mmv MOVE_DOWN &mmv MOVE_RIGHT &none    &none
&none           &tog ALT_LAYER   &none         &none         &none         &none    &none          &none          &none      &mkp LCLK  &mkp MCLK      &mkp RCLK    &none        &none
                        &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&rot_none &rot_none>;
        };
    };
};
